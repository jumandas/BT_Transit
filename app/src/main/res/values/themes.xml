<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — no ActionBar, Compose owns the UI -->
    <style name="Theme.BT_Transit" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash screen theme shown during cold start -->
    <style name="Theme.EasyTransit.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A6CB5</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">#0A6CB5</item>
        <item name="postSplashScreenTheme">@style/Theme.BT_Transit</item>
    </style>
</resources>
